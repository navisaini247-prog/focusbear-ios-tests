<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/widget_bg"
    android:elevation="4dp"
    android:padding="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/widget_header_bg"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:minHeight="70dp">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:scaleType="fitCenter"
            android:src="@drawable/focus_bear_icon"
            android:layout_marginEnd="10dp"
            android:contentDescription="@string/widget_focus_bear_icon" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/widget_no_reason_provided"
            android:textColor="@color/widget_header_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/widget_preview_next_habit"
            android:textColor="@color/widget_text"
            android:textSize="16sp"
            android:padding="12dp"
            android:minHeight="48dp"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>

</LinearLayout>
