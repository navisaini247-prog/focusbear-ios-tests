<?xml version="1.0" encoding="utf-8"?>
<!-- Compact: header only with icon + blocking reason -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_background_orange"
    android:padding="12dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/widget_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:scaleType="fitCenter"
        android:src="@drawable/focus_bear_icon"
        android:contentDescription="@string/widget_focus_bear_logo"
        android:layout_marginEnd="6dp" />

    <TextView
        android:id="@+id/widget_blocking_reason"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/app_name"
        android:textColor="@color/widget_header_text"
        android:textSize="14sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end" />

</LinearLayout>
