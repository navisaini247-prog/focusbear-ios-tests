{
  "name": "FocusBear",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android --mode=developmentDebug",
    "android:prod": "react-native run-android --variant=productionDebug",
    "android:staging": "react-native run-android --variant=stagingDebug",
    "android:cleanRun": "cd android && gradlew clean && cd .. && yarn android",
    "android:generateAssets": "cd android && ./gradlew clean && rm -rf app/src/main/assets/index.android.bundle && cd .. && npx react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "android:buildDebug": "cd android && ./gradlew clean && rm -rf app/src/main/assets/index.android.bundle && cd .. && watchman watch-del-all && npx react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res && cd android && ENVFILE=.env.staging ./gradlew assembleDebug && cd .. ",
    "android:buildDev": "cd android && ./gradlew clean && rm -rf app/src/main/assets/index.android.bundle && cd .. && watchman watch-del-all && npx react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res && cd android && ENVFILE=.env.development ./gradlew assembleRelease && cd .. ",
    "android:buildProd": "cd android && ENVFILE=.env.production ./gradlew assembleRelease && cd .. ",
    "android:bundleProd": "cd android && ENVFILE=.env.production ./gradlew bundleRelease && cd .. ",
    "ios": "node scripts/ios-simulator.js Development",
    "ios:prod": "node scripts/ios-simulator.js Production",
    "ios:staging": "node scripts/ios-simulator.js Staging",
    "build:ios": "react-native bundle --entry-file='index.js' --bundle-output='./ios/main.jsbundle' --dev=false --platform='ios'",
    "bundle:ios": "react-native bundle --entry-file index.js --platform ios --dev false --bundle-output ios/main.jsbundle --assets-dest ios",
    "clean": "watchman watch-del-all && rm -rf package-lock.json && rm -rf node_modules && npm install",
    "start": "react-native start",
    "test": "jest",
    "test:ci": "jest",
    "lint": "eslint . --quiet",
    "postinstall": "patch-package && npx jetify && npx pod-install",
    "np": "np --no-publish",
    "postversion": "react-native-version",
    "lint-staged": "lint-staged --config lint-staged.js",
    "husky-install": "husky install",
    "bundle:android": "./script/android-build-script.sh",
    "sourcemaps:android": "node_modules/.bin/react-native bundle --platform android --entry-file index.js --dev false --reset-cache --bundle-output /tmp/bundle.android.js --assets-dest /tmp/ --sourcemap-output sourcemaps/android/index.js.map",
    "sourcemaps:ios": "node_modules/.bin/react-native bundle --platform ios --entry-file index.js --dev false --reset-cache --bundle-output /tmp/bundle.ios.js --assets-dest /tmp/ --sourcemap-output sourcemaps/ios/index.js.map",
    "storybook:generate": "sb-rn-get-stories --config-path .storybook",
    "storybook:android": "STORYBOOK_ENABLED=true react-native run-android --mode=developmentDebug --port 8082",
    "storybook:ios": "STORYBOOK_ENABLED=true react-native run-ios --scheme 'Development' --simulator 'iPhone 17 Pro' --port 8082",
    "storybook:start": "STORYBOOK_ENABLED=true react-native start --port 8082"
  },
